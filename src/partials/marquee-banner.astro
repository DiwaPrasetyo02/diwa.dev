---
const text =
  "// AI ENGINEER // DATA DRIVEN // ML OPS // DEEP LEARNING // COMPUTER VISION // NLP // "; 
---

<div
  class="border-y-4 border-black bg-[#FFC900] overflow-hidden py-5 select-none"
  aria-hidden="true"
>
  <div class="flex animate-marquee md:animate-marquee-slow whitespace-nowrap">
    <span
      class="font-heading text-2xl md:text-4xl font-black italic uppercase tracking-tight text-black"
    >
      {text}{text}{text}{text}{text}{text}
    </span>
  </div>
</div>
